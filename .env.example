# ========================================
# REQUIRED SETTINGS
# ========================================
# Path to open-interpreter clone
# Set ONE of: OI_PATH, OI_PATH_WIN (Windows), OI_PATH_LINUX (Linux)
# OI_PATH=/path/to/open-interpreter
# OI_PATH_WIN=D:/path/to/open-interpreter
# OI_PATH_LINUX=/mnt/d/path/to/open-interpreter

# ========================================
# API KEYS
# ========================================
# Gemini API key (required for Gemini-based features)
GEMINI_API_KEY=your-api-key-here

# ========================================
# SERVER SETTINGS
# ========================================
# HOST=0.0.0.0
# PORT=8000

# ========================================
# TOOL CONFIGURATION
# ========================================
# MCP_TOOL_TIMEOUT=60000

# ========================================
# SECURITY SETTINGS
# ========================================
# Allow unsafe commands (default: false). Set to true to bypass command denylist.
# ALLOW_UNSAFE_COMMANDS=false

# Enable risky computer actions without confirmation (default: true for backward compat).
# Set to false in production for user confirmation before mouse/keyboard actions.
# RISKY_ACTION_ENABLED=true

# Max computer actions per minute (rate limiting, default: 60)
# COMPUTER_ACTION_RATE_LIMIT=60

# ========================================
# SCREENSHOT CONFIGURATION
# ========================================
# MCP_SCREENSHOT_SCALING=1
# MCP_MAX_SCREENSHOT_WIDTH=1366
# MCP_MAX_SCREENSHOT_HEIGHT=768
# MCP_CAPTURE_SCOPE=primary

# ========================================
# UI SCANNING
# ========================================
# MCP_AUTO_SCAN_ALWAYS=0
# MCP_AUTO_SCAN_ON_CHANGE=1
# MCP_AUTO_SCAN_MAX_ELEMENTS=60
# MCP_UI_SCAN_BROWSER_ELEMENT_LIMIT=80
# MCP_UI_SCAN_BROWSER_MAX_DEPTH=3
# MCP_UI_SCAN_BROWSER_ACTIVE_ONLY=1

# ========================================
# INPUT/OVERLAY TUNING
# ========================================
# MCP_MOVE_DURATION_MS=150
# MCP_OVERLAY_MIN_HOLD_MS=450
# MCP_OVERLAY_FADE_MS=260
# MCP_TYPE_INTERVAL_SEC=0.02
# MCP_COORDINATE_GRID=0

# ========================================
# BROWSER CONFIGURATION
# ========================================
# BROWSER_CDP_PORT=9222

# ========================================
# HYBRID MODE (Browser-Use)
# ========================================
# BROWSER_USE_PYTHON=
# BROWSER_USE_HEADLESS=0
# HYBRID_DEBUG=0
# HYBRID_BU_START_TIMEOUT_S=25.0
# HYBRID_BU_CALL_TIMEOUT_S=25.0
# HYBRID_BU_ERRLOG_PATH=

# ========================================
# VOICE SERVER (Optional)
# ========================================
# VOICE_SCREEN_W=
# VOICE_SCREEN_H=

# ========================================
# BROWSER-USE LOGGING
# ========================================
# BROWSER_USE_LOGGING_LEVEL=warning
# BROWSER_USE_SETUP_LOGGING=0
