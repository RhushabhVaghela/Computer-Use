# ============================================================================
# REQUIRED: Open Interpreter Path Configuration
# ============================================================================
# Path to your local open-interpreter clone. This is REQUIRED for deployment.
# The application will fail to start if these are not set.
#
# Choose ONE of the following based on your platform:
#   - OI_PATH_WIN: Windows-specific path (takes priority on Windows)
#   - OI_PATH_LINUX: Linux-specific path (takes priority on Linux)
#   - OI_PATH: Generic fallback path (used if platform-specific vars not set)
#
# REQUIRED SETUP (choose at least one):
OI_PATH_WIN="d:\Agents-and-other-repos\open-interpreter"
OI_PATH_LINUX="/mnt/d/Agents-and-other-repos/open-interpreter"
OI_PATH="d:\Agents-and-other-repos\open-interpreter"
# ============================================================================

# LLM API Keys (used by Open Interpreter for vision/code execution)
# ANTHROPIC_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# Server config (defaults shown)
# HOST=0.0.0.0
# PORT=8000

# MCP tool timeout in ms (default: 60000)
# MCP_TOOL_TIMEOUT=60000

# ============================================================================
# Voice Server Screen Dimensions (Optional)
# ============================================================================
# Query actual screen dimensions at runtime via pyautogui.size()
# If query fails, fallback is 1920x1080
# Uncomment to override with specific values:
# VOICE_SCREEN_W=2560
# VOICE_SCREEN_H=1600

# ============================================================================
# Overlay / Input Tuning
# ============================================================================
# Smooth mouse move duration (ms)
# MCP_MOVE_DURATION_MS=150
# Minimum time to hold overlay text before changing again (ms)
# MCP_OVERLAY_MIN_HOLD_MS=450
# Overlay fade-in duration (ms)
# MCP_OVERLAY_FADE_MS=260
# Per-character typing interval (seconds)
# MCP_TYPE_INTERVAL_SEC=0.02

# ============================================================================
# Verification / Scanning
# ============================================================================
# Auto UI scan after EVERY computer action (slower, but verifies minute actions)
# MCP_AUTO_SCAN_ALWAYS=1
# Auto UI scan only when screen changed (default: 1). Leave enabled unless you use ALWAYS.
# MCP_AUTO_SCAN_ON_CHANGE=1
# Limit UI elements returned in scans
# MCP_AUTO_SCAN_MAX_ELEMENTS=60

# Speed up scans when the active window is a browser (Chrome/Edge/Brave)
# MCP_UI_SCAN_BROWSER_ELEMENT_LIMIT=80
# MCP_UI_SCAN_BROWSER_MAX_DEPTH=3
# MCP_UI_SCAN_BROWSER_ACTIVE_ONLY=1

# ============================================================================
# Hybrid Mode (browser-use proxy)
# ============================================================================
# Optional: override the python used to launch browser-use MCP server
# (default: ..\\browser-use\\.venv\\Scripts\\python.exe)
# BROWSER_USE_PYTHON=
# Optional: force browser-use headless mode (default profile is headless=false)
# BROWSER_USE_HEADLESS=0
