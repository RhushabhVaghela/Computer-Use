+    /// Load hands from an external directory.
+    /// Scans the directory for subfolders, each containing a HAND.toml and optionally a SKILL.md.
+    pub fn load_external_hands(&mut self, path: &Path) -> HandResult<usize> {
+        if !path.is_dir() {
+            return Ok(0);
+        }
+
+        let mut count = 0;
+        for entry in std::fs::read_dir(path)? {
+            let entry = entry?;
+            let path = entry.path();
+            if path.is_dir() {
+                let id = path
+                    .file_name()
+                    .and_then(|n| n.to_str())
+                    .unwrap_or("unknown")
+                    .to_string();
+                let toml_path = path.join("HAND.toml");
+                let skill_path = path.join("SKILL.md");
+
+                if toml_path.exists() {
+                    let toml_content = std::fs::read_to_string(&toml_path)?;
+                    let skill_content = if skill_path.exists() {
+                        std::fs::read_to_string(&skill_path)?
+                    } else {
+                        String::new()
+                    };
+
+                    match bundled::parse_bundled(&id, &toml_content, &skill_content) {
+                        Ok(mut def) => {
+                            // Ensure ID matches folder name if missing/different?
+                            // Actually parse_bundled uses the ID from TOML if present.
+                            // We trust the TOML but the folder name is a good fallback.
+                            if def.id.is_empty() {
+                                def.id = id.clone();
+                            }
+                            info!(hand = %def.id, name = %def.name, path = ?toml_path, "Loaded external hand");
+                            self.definitions.insert(def.id.clone(), def);
+                            count += 1;
+                        }
+                        Err(e) => {
+                            warn!(hand = %id, path = ?toml_path, error = %e, "Failed to parse external hand");
+                        }
+                    }
+                }
+            }
+        }
+        Ok(count)
+    }
+
     /// List all known hand definitions.
     pub fn list_definitions(&self) -> Vec<&HandDefinition> {
         let mut defs: Vec<&HandDefinition> = self.definitions.values().collect();
